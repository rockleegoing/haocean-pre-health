{
  "permissions": {
    "allow": [
      "Bash(git init:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",
      "Bash(git push:*)",
      "Bash(ssh:*)",
      "Bash(ssh-keygen:*)",
      "WebFetch(domain:mp.weixin.qq.com)",
      "WebFetch(domain:ruoyi-go.qiqjia.com)",
      "mcp__uni-app-x-mcp__Query_all_components_under_the_project",
      "WebFetch(domain:doc.dcloud.net.cn)",
      "WebFetch(domain:uniapp.dcloud.net.cn)",
      "WebFetch(domain:uviewui.com)",
      "WebSearch",
      "WebFetch(domain:www.uviewui.com)",
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Git(*)",
      "Npm(*)",
      "Pip(*)",
      "Bash(go test:*)",
      "Bash(go build:*)"
    ],
    "allowMultilineCommands": true
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "uni-app-x-mcp"
  ],
  "hooks": {
    "afterUserMessage": {
      "if": "用户提到移动端、UniApp、小程序等关键词",
      "then": "自动读取 docs/MOBILE.md 和 docs/STANDARD.md，并参考 frontend/Haocean-Mobile/pages/ 目录下的现有页面"
    },
    "beforeFinalAnswer": {
      "if": "生成了代码修改或新增文件",
      "then": "检查代码是否符合项目规范（STANDARD.md），并提醒用户运行编译/预览命令"
    }
  }
}
